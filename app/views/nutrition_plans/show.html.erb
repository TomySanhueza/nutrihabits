<div class="nh-backoffice nh-nutrition-plan-show">
  <%= render "shared/nutritionist_sidebar", active: :plans, patient: @patient %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <%= render "shared/nutritionist_page_header",
        eyebrow: "Detalle de plan",
        title: @nutrition_plan.objective.presence || "Plan sin objetivo",
        description: "#{@patient.first_name} #{@patient.last_name} · #{nutritionist_backoffice_date_range(@nutrition_plan.start_date, @nutrition_plan.end_date)}",
        primary_action: { label: "Editar plan", path: edit_patient_nutrition_plan_path(@patient, @nutrition_plan) },
        secondary_action: { label: "Volver a planes", path: patient_nutrition_plans_path(@patient) } %>

      <section class="nh-stat-grid" aria-label="Resumen del plan">
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Estado</p>
          <p class="nh-stat-card__value"><%= nutrition_plan_status_name(@nutrition_plan.status) %></p>
          <p class="nh-stat-card__hint">Estado operativo actual del plan.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Vigencia</p>
          <p class="nh-stat-card__value"><%= nutritionist_backoffice_date_range(@nutrition_plan.start_date, @nutrition_plan.end_date) %></p>
          <p class="nh-stat-card__hint"><%= pluralize(@daily_plans.size, "día", "días") %> programados.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Calorías</p>
          <p class="nh-stat-card__value"><%= formatted_quantity(@nutrition_plan.calories, unit: "kcal") %></p>
          <p class="nh-stat-card__hint">Objetivo energético diario.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Macros</p>
          <p class="nh-stat-card__value"><%= nutrition_plan_macro_summary(@nutrition_plan) %></p>
          <p class="nh-stat-card__hint">Distribución global del plan.</p>
        </article>
      </section>

      <section class="nh-grid nh-grid--content">
        <section class="nh-panel">
          <div class="nh-section-header">
            <div>
              <p class="nh-section__eyebrow">Plan diario</p>
              <h2 class="nh-section__title">Distribución de comidas</h2>
              <p class="nh-section__description">Vista diaria con comidas, estado y macros por cada bloque.</p>
            </div>
          </div>

          <% if @daily_plans.any? %>
            <div class="nh-plan-show__days">
              <% @daily_plans.each do |daily_plan| %>
                <article class="nh-plan-show__day">
                  <header class="nh-plan-show__day-header">
                    <div>
                      <p class="nh-list__title"><%= l(daily_plan.date, format: :long) %></p>
                      <p class="nh-list__meta">
                        <% if daily_plan.mood.present? %>
                          Estado de ánimo: <%= daily_plan.mood %>
                        <% end %>
                        <% if daily_plan.energy_level.present? %>
                          <% if daily_plan.mood.present? %> · <% end %>
                          Energía: <%= daily_plan.energy_level %>
                        <% end %>
                        <% if daily_plan.activity.present? %>
                          · Actividad: <%= daily_plan.activity %>
                        <% end %>
                      </p>
                    </div>
                    <span class="nh-badge nh-badge--muted"><%= pluralize(daily_plan.meals.size, "comida", "comidas") %></span>
                  </header>

                  <% if daily_plan.meals.any? %>
                    <div class="nh-plan-show__meals">
                      <% daily_plan.meals.each do |meal| %>
                        <article class="nh-plan-show__meal">
                          <div class="nh-plan-show__meal-header">
                            <div>
                              <p class="nh-list__title"><%= meal_type_icon(meal.meal_type) %> <%= meal_type_name(meal.meal_type) %></p>
                              <p class="nh-list__meta"><%= meal.ingredients.presence || "Sin ingredientes cargados" %></p>
                            </div>
                            <span class="<%= nutritionist_backoffice_badge_class(meal_status_modifier(meal.status)) %>">
                              <%= meal_status_name(meal.status) %>
                            </span>
                          </div>

                          <% if meal.recipe.present? %>
                            <p class="nh-body-copy"><strong>Preparación:</strong> <%= meal.recipe %></p>
                          <% end %>

                          <dl class="nh-detail-grid nh-plan-show__meal-macros">
                            <div>
                              <dt>Calorías</dt>
                              <dd><%= formatted_quantity(meal.calories, unit: "kcal") %></dd>
                            </div>
                            <div>
                              <dt>Proteína</dt>
                              <dd><%= formatted_quantity(meal.protein, unit: "g") %></dd>
                            </div>
                            <div>
                              <dt>Carbohidratos</dt>
                              <dd><%= formatted_quantity(meal.carbs, unit: "g") %></dd>
                            </div>
                            <div>
                              <dt>Grasas</dt>
                              <dd><%= formatted_quantity(meal.fat, unit: "g") %></dd>
                            </div>
                          </dl>
                        </article>
                      <% end %>
                    </div>
                  <% else %>
                    <%= render "shared/nutritionist_empty_state",
                      title: "Sin comidas programadas.",
                      body: "Este día aún no tiene comidas cargadas dentro del plan." %>
                  <% end %>
                </article>
              <% end %>
            </div>
          <% else %>
            <%= render "shared/nutritionist_empty_state",
              title: "No hay días programados.",
              body: "Este plan todavía no tiene estructura diaria cargada." %>
          <% end %>
        </section>

        <aside class="nh-stack">
          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Notas</p>
                <h2 class="nh-section__title">Contexto clínico</h2>
              </div>
            </div>

            <% if @nutrition_plan.notes.present? %>
              <div class="nh-body-copy"><%= simple_format(@nutrition_plan.notes) %></div>
            <% else %>
              <%= render "shared/nutritionist_empty_state",
                title: "Sin notas clínicas.",
                body: "Este plan no tiene observaciones adicionales del nutricionista." %>
            <% end %>
          </section>

          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Paciente</p>
                <h2 class="nh-section__title">Acciones relacionadas</h2>
              </div>
            </div>

            <dl class="nh-detail-list">
              <div>
                <dt>Paciente</dt>
                <dd><%= @patient.first_name %> <%= @patient.last_name %></dd>
              </div>
              <div>
                <dt>Acceso app</dt>
                <dd><%= onboarding_state_name(@patient.onboarding_state) %></dd>
              </div>
            </dl>

            <div class="nh-inline-actions">
              <%= link_to "Ver paciente", patient_path(@patient), class: "nh-button nh-button--secondary" %>
              <%= link_to "Editar plan", edit_patient_nutrition_plan_path(@patient, @nutrition_plan), class: "nh-button nh-button--ghost" %>
            </div>
          </section>
        </aside>
      </section>
    </div>
  </main>
</div>
