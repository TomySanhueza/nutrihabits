<div class="nh-meal-fields nested-fields">
  <%= f.hidden_field :_destroy %>

  <section class="nh-meal-fields__card">
    <div class="nh-section-header">
      <div>
        <p class="nh-section__eyebrow">Comida</p>
        <h5 class="nh-section__title">Bloque alimentario</h5>
      </div>
      <button type="button"
              class="nh-button nh-button--secondary nh-button--small"
              data-action="click->nested-form#remove_association">
        Eliminar
      </button>
    </div>

    <div class="nh-form-grid nh-form-grid--two">
      <div>
        <%= f.input :meal_type,
          label: "Tipo de comida",
          collection: [
            [ "Desayuno", "breakfast" ],
            [ "Almuerzo", "lunch" ],
            [ "Cena", "dinner" ],
            [ "Snack", "snack" ]
          ],
          include_blank: "Seleccionar",
          input_html: { class: "nh-form-select" } %>
      </div>
      <div>
        <%= f.input :status,
          label: "Estado",
          collection: [
            [ "Pendiente", "pending" ],
            [ "Registrada", "logged" ],
            [ "Omitida", "skipped" ]
          ],
          include_blank: "Seleccionar",
          input_html: { class: "nh-form-select" } %>
      </div>
    </div>

    <div>
      <%= f.input :ingredients,
        label: "Ingredientes",
        as: :text,
        input_html: { class: "nh-form-textarea", rows: 3, placeholder: "Ej: 2 huevos, 50 g avena, fruta fresca..." } %>
    </div>

    <div>
      <%= f.input :recipe,
        label: "Preparación",
        as: :text,
        input_html: { class: "nh-form-textarea", rows: 3, placeholder: "Pasos o instrucciones principales..." } %>
    </div>

    <div class="nh-form-grid nh-form-grid--two nh-meal-fields__macros">
      <div>
        <%= f.input :calories, label: "Calorías (kcal)", input_html: { class: "nh-form-input", placeholder: "450" } %>
      </div>
      <div>
        <%= f.input :protein, label: "Proteína (g)", input_html: { class: "nh-form-input", placeholder: "30" } %>
      </div>
      <div>
        <%= f.input :carbs, label: "Carbohidratos (g)", input_html: { class: "nh-form-input", placeholder: "45" } %>
      </div>
      <div>
        <%= f.input :fat, label: "Grasas (g)", input_html: { class: "nh-form-input", placeholder: "15" } %>
      </div>
    </div>
  </section>
</div>
