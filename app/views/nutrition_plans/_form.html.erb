<%= simple_form_for [@patient, @nutrition_plan], html: { class: "nh-stack", data: { controller: "nested-form" } } do |f| %>
  <section class="nh-form-section">
    <div class="nh-form-section__header">
      <h2 class="nh-form-section__title">Resumen del plan</h2>
      <p class="nh-form-section__copy">Objetivo, rango de fechas y notas clínicas de este plan.</p>
    </div>

    <div class="nh-form-grid">
      <div>
        <%= f.input :objective,
          label: "Objetivo",
          input_html: { class: "nh-form-input", placeholder: "Ej: Recomposición corporal, control glucémico..." } %>
      </div>

      <div class="nh-form-grid nh-form-grid--two">
        <div>
          <%= f.input :start_date, label: "Fecha de inicio", as: :date, input_html: { class: "nh-form-input" } %>
        </div>
        <div>
          <%= f.input :end_date, label: "Fecha de término", as: :date, input_html: { class: "nh-form-input" } %>
        </div>
      </div>

      <div>
        <%= f.input :notes,
          as: :text,
          label: "Notas clínicas",
          input_html: { class: "nh-form-textarea", rows: 4, placeholder: "Contexto, alertas, instrucciones especiales..." } %>
      </div>
    </div>
  </section>

  <section class="nh-form-section">
    <div class="nh-form-section__header">
      <h2 class="nh-form-section__title">Macros objetivo</h2>
      <p class="nh-form-section__copy">Valores diarios base que guían la estructura de comidas.</p>
    </div>

    <div class="nh-form-grid nh-form-grid--two nh-nutrition-form__macro-grid">
      <div>
        <%= f.input :calories, label: "Calorías (kcal)", input_html: { class: "nh-form-input", placeholder: "1800" } %>
      </div>
      <div>
        <%= f.input :protein, label: "Proteína (g)", input_html: { class: "nh-form-input", placeholder: "120" } %>
      </div>
      <div>
        <%= f.input :carbs, label: "Carbohidratos (g)", input_html: { class: "nh-form-input", placeholder: "210" } %>
      </div>
      <div>
        <%= f.input :fat, label: "Grasas (g)", input_html: { class: "nh-form-input", placeholder: "60" } %>
      </div>
    </div>
  </section>

  <section class="nh-form-section">
    <div class="nh-section-header">
      <div>
        <h2 class="nh-form-section__title">Planes diarios</h2>
        <p class="nh-form-section__copy">Cada día puede contener varias comidas con macros y notas propias.</p>
      </div>
      <button type="button"
              class="nh-button nh-button--secondary"
              data-action="click->nested-form#add_association"
              data-association-insertion-node="#plans"
              data-association-insertion-method="append">
        Agregar día
      </button>
    </div>

    <div id="plans" class="nh-stack">
      <%= f.simple_fields_for :plans do |plan_form| %>
        <%= render "plan_fields", f: plan_form %>
      <% end %>
    </div>

    <% if @nutrition_plan.plans.empty? %>
      <div class="nh-nutrition-form__empty">
        <%= render "shared/nutritionist_empty_state",
          title: "Todavía no hay días cargados.",
          body: "Agrega el primer día para estructurar comidas y notas por jornada." %>
      </div>
    <% end %>

    <template data-nested-form-target="template">
      <%= f.simple_fields_for :plans, Plan.new, child_index: "TEMPLATE_RECORD" do |plan_form| %>
        <%= render "plan_fields", f: plan_form %>
      <% end %>
    </template>
  </section>

  <div class="nh-form-actions">
    <%= link_to "Cancelar", patient_nutrition_plan_path(@patient, @nutrition_plan), class: "nh-button nh-button--secondary" %>
    <%= f.submit "Guardar plan", class: "nh-button nh-button--primary" %>
  </div>
<% end %>
