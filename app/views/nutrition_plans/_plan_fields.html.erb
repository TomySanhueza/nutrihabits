<div class="nh-plan-fields nested-fields" data-controller="nested-form">
  <%= f.hidden_field :_destroy %>

  <section class="nh-plan-fields__card">
    <div class="nh-section-header">
      <div>
        <p class="nh-section__eyebrow">Día</p>
        <h3 class="nh-section__title">Plan diario</h3>
      </div>
      <button type="button"
              class="nh-button nh-button--secondary nh-button--small"
              data-action="click->nested-form#remove_association">
        Eliminar día
      </button>
    </div>

    <div class="nh-form-grid nh-form-grid--two">
      <div>
        <%= f.input :date, label: "Fecha", as: :date, html5: true, input_html: { class: "nh-form-input" } %>
      </div>
      <div>
        <%= f.input :activity,
          label: "Actividad física",
          collection: [ "Sedentario", "Ligero", "Moderado", "Activo", "Muy activo" ],
          include_blank: "Seleccionar",
          input_html: { class: "nh-form-select" } %>
      </div>
      <div>
        <%= f.input :mood,
          label: "Estado de ánimo",
          collection: [ "Excelente", "Bueno", "Normal", "Bajo", "Muy bajo" ],
          include_blank: "Seleccionar",
          input_html: { class: "nh-form-select" } %>
      </div>
      <div>
        <%= f.input :energy_level,
          label: "Nivel de energía",
          collection: [ "Muy alto", "Alto", "Medio", "Bajo", "Muy bajo" ],
          include_blank: "Seleccionar",
          input_html: { class: "nh-form-select" } %>
      </div>
    </div>

    <div>
      <%= f.input :notes,
        label: "Notas del día",
        as: :text,
        input_html: { class: "nh-form-textarea", rows: 3, placeholder: "Observaciones o instrucciones específicas de la jornada..." } %>
    </div>

    <div class="nh-plan-fields__meals">
      <div class="nh-section-header">
        <div>
          <p class="nh-section__eyebrow">Comidas</p>
          <h4 class="nh-section__title">Bloques del día</h4>
        </div>
        <button type="button"
                class="nh-button nh-button--secondary nh-button--small"
                data-action="click->nested-form#add_association"
                data-association-insertion-node=".meals-<%= f.object.object_id %>"
                data-association-insertion-method="append">
          Agregar comida
        </button>
      </div>

      <div class="nh-stack meals-<%= f.object.object_id %>">
        <%= f.simple_fields_for :meals do |meal_form| %>
          <%= render "meal_fields", f: meal_form %>
        <% end %>
      </div>

      <template data-nested-form-target="template">
        <%= f.simple_fields_for :meals, Meal.new, child_index: "TEMPLATE_RECORD" do |meal_form| %>
          <%= render "meal_fields", f: meal_form %>
        <% end %>
      </template>
    </div>
  </section>
</div>
