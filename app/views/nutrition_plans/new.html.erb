<div class="nh-backoffice nh-nutrition-plan-new">
  <%= render "shared/nutritionist_sidebar", active: :plans, patient: @patient %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <% if @patient.profile.present? %>
        <%= render "shared/nutritionist_page_header",
          eyebrow: "Preparar plan IA",
          title: "Nuevo plan para #{@patient.first_name} #{@patient.last_name}",
          description: "Esta vista resume el contexto clínico que se usará para generar el borrador inicial.",
          primary_action: { label: "Generar borrador con IA", path: patient_nutrition_plans_path(@patient), method: :post },
          secondary_action: { label: "Volver a planes", path: patient_nutrition_plans_path(@patient) } %>
      <% else %>
        <%= render "shared/nutritionist_page_header",
          eyebrow: "Preparar plan IA",
          title: "Nuevo plan para #{@patient.first_name} #{@patient.last_name}",
          description: "Antes de generar el plan debes completar la ficha clínica del paciente.",
          secondary_action: { label: "Volver a planes", path: patient_nutrition_plans_path(@patient) } %>
      <% end %>

      <% if flash.now[:alert].present? || flash[:alert].present? %>
        <section class="nh-panel">
          <p class="nh-body-copy"><%= flash.now[:alert] || flash[:alert] %></p>
        </section>
      <% end %>

      <% if @patient.profile.present? %>
        <section class="nh-grid nh-grid--content">
          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Contexto clínico</p>
                <h2 class="nh-section__title">Datos que usará la generación</h2>
              </div>
            </div>

            <dl class="nh-detail-list">
              <div>
                <dt>Peso</dt>
                <dd><%= formatted_weight(@patient.profile.weight) %></dd>
              </div>
              <div>
                <dt>Altura</dt>
                <dd><%= formatted_quantity(@patient.profile.height, unit: "cm") %></dd>
              </div>
              <div>
                <dt>Objetivos</dt>
                <dd><%= @patient.profile.goals.presence || "Sin objetivos registrados" %></dd>
              </div>
              <div>
                <dt>Condiciones</dt>
                <dd><%= @patient.profile.conditions.presence || "Sin condiciones registradas" %></dd>
              </div>
              <div>
                <dt>Estilo de vida</dt>
                <dd><%= @patient.profile.lifestyle.presence || "Sin información registrada" %></dd>
              </div>
              <div>
                <dt>Diagnóstico</dt>
                <dd><%= @patient.profile.diagnosis.presence || "Sin diagnóstico registrado" %></dd>
              </div>
            </dl>

            <% if @recent_histories.any? %>
              <div class="nh-nutrition-plan-new__subsection">
                <h3 class="nh-section__title">Controles recientes</h3>
                <div class="nh-list">
                  <% @recent_histories.each do |history| %>
                    <article class="nh-list__item">
                      <div>
                        <p class="nh-list__title"><%= l(history.visit_date, format: :long) %></p>
                        <p class="nh-list__meta">
                          <%= history.weight.present? ? formatted_weight(history.weight) : "Sin peso registrado" %>
                          <% if history.nutrition_plan.present? %>
                            · Vinculado a <%= history.nutrition_plan.objective.presence || "plan sin objetivo" %>
                          <% end %>
                        </p>
                      </div>
                    </article>
                  <% end %>
                </div>
              </div>
            <% end %>
          </section>

          <aside class="nh-stack">
            <section class="nh-panel">
              <div class="nh-section-header">
                <div>
                  <p class="nh-section__eyebrow">Salida esperada</p>
                  <h2 class="nh-section__title">Qué se generará</h2>
                </div>
              </div>

              <div class="nh-list">
                <article class="nh-list__item">
                  <div>
                    <p class="nh-list__title">Plan base de 7 días</p>
                    <p class="nh-list__meta">Con días, comidas, macros y notas iniciales.</p>
                  </div>
                </article>
                <article class="nh-list__item">
                  <div>
                    <p class="nh-list__title">Borrador editable</p>
                    <p class="nh-list__meta">Después de generar, podrás revisar y editar cada comida antes de cerrar.</p>
                  </div>
                </article>
                <article class="nh-list__item">
                  <div>
                    <p class="nh-list__title">Historial preservado</p>
                    <p class="nh-list__meta">Los planes previos no se tocan; este borrador se crea como un registro nuevo.</p>
                  </div>
                </article>
              </div>

              <% if @latest_plan.present? %>
                <div class="nh-nutrition-plan-new__subsection">
                  <h3 class="nh-section__title">Último plan existente</h3>
                  <p class="nh-body-copy"><%= @latest_plan.objective.presence || "Plan sin objetivo" %></p>
                  <p class="nh-small-copy"><%= nutritionist_backoffice_date_range(@latest_plan.start_date, @latest_plan.end_date) %></p>
                </div>
              <% end %>

              <%= button_to "Generar borrador con IA", patient_nutrition_plans_path(@patient), method: :post, class: "nh-button nh-button--primary", form: { class: "nh-inline-form nh-nutrition-plan-new__cta" } %>
            </section>
          </aside>
        </section>
      <% else %>
        <%= render "shared/nutritionist_empty_state",
          title: "Falta el perfil clínico del paciente.",
          body: "Completa peso, altura, objetivos y contexto antes de generar un plan nutricional.",
          action: { label: "Completar perfil", path: new_patient_profile_path(@patient) } %>
      <% end %>
    </div>
  </main>
</div>
