<div class="nh-backoffice nh-nutrition-plans-index">
  <%= render "shared/nutritionist_sidebar", active: :plans, patient: @patient %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <% primary_action = @patient.profile.present? ? { label: "Preparar plan", path: new_patient_nutrition_plan_path(@patient) } : { label: "Completar perfil", path: new_patient_profile_path(@patient) } %>
      <%= render "shared/nutritionist_page_header",
        eyebrow: "Planes nutricionales",
        title: "Planes de #{@patient.first_name} #{@patient.last_name}",
        description: "Historial de planes con estado, vigencia y acceso directo a edición.",
        primary_action: primary_action,
        secondary_action: { label: "Volver al paciente", path: patient_path(@patient) } %>

      <section class="nh-stat-grid" aria-label="Resumen de planes">
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Total</p>
          <p class="nh-stat-card__value"><%= @nutrition_plan_stats[:total] %></p>
          <p class="nh-stat-card__hint">Planes generados para este paciente.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Activos</p>
          <p class="nh-stat-card__value"><%= @nutrition_plan_stats[:active] %></p>
          <p class="nh-stat-card__hint">Planes vigentes o en curso.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Borradores</p>
          <p class="nh-stat-card__value"><%= @nutrition_plan_stats[:draft] %></p>
          <p class="nh-stat-card__hint">Planes pendientes de cierre.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Completados</p>
          <p class="nh-stat-card__value"><%= @nutrition_plan_stats[:completed] %></p>
          <p class="nh-stat-card__hint">Planes ya cerrados.</p>
        </article>
      </section>

      <section class="nh-grid nh-grid--content">
        <section class="nh-panel">
          <div class="nh-section-header">
            <div>
              <p class="nh-section__eyebrow">Historial</p>
              <h2 class="nh-section__title">Listado de planes</h2>
              <p class="nh-section__description">Cada fila mantiene una acción primaria y una secundaria para evitar ruido visual.</p>
            </div>
          </div>

          <% if @nutrition_plans.any? %>
            <table class="nh-table">
              <thead>
                <tr>
                  <th>Objetivo</th>
                  <th>Vigencia</th>
                  <th>Estado y macros</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% @nutrition_plans.each do |plan| %>
                  <tr>
                    <td>
                      <p class="nh-list__title"><%= plan.objective.presence || "Plan sin objetivo" %></p>
                      <p class="nh-table__subcopy"><%= plan.notes.present? ? truncate(plan.notes, length: 120) : "Sin notas clínicas adicionales." %></p>
                    </td>
                    <td>
                      <p class="nh-body-copy"><%= nutritionist_backoffice_date_range(plan.start_date, plan.end_date) %></p>
                      <p class="nh-table__subcopy"><%= pluralize(plan.plans.size, "día", "días") %> cargados</p>
                    </td>
                    <td>
                      <div class="nh-pill-list">
                        <span class="<%= nutritionist_backoffice_badge_class(nutrition_plan_status_badge_modifier(plan.status)) %>">
                          <%= nutrition_plan_status_name(plan.status) %>
                        </span>
                      </div>
                      <p class="nh-table__subcopy"><%= nutrition_plan_macro_summary(plan) %></p>
                    </td>
                    <td>
                      <div class="nh-inline-actions">
                        <%= link_to "Ver detalle", patient_nutrition_plan_path(@patient, plan), class: "nh-button nh-button--primary nh-button--small" %>
                        <%= link_to "Editar", edit_patient_nutrition_plan_path(@patient, plan), class: "nh-button nh-button--secondary nh-button--small" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <%= render "shared/nutritionist_empty_state",
              title: "No hay planes nutricionales.",
              body: "Aún no se ha creado ningún plan para este paciente.",
              action: primary_action %>
          <% end %>
        </section>

        <aside class="nh-stack">
          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Paciente</p>
                <h2 class="nh-section__title">Contexto rápido</h2>
              </div>
            </div>

            <dl class="nh-detail-list">
              <div>
                <dt>Acceso app</dt>
                <dd><%= onboarding_state_name(@patient.onboarding_state) %></dd>
              </div>
              <div>
                <dt>Perfil clínico</dt>
                <dd><%= patient_profile_status(@patient.profile) %></dd>
              </div>
              <div>
                <dt>Email</dt>
                <dd><%= @patient.email %></dd>
              </div>
              <div>
                <dt>Último plan activo</dt>
                <dd><%= @patient.active_nutrition_plan&.objective.presence || "Sin plan vigente" %></dd>
              </div>
            </dl>

            <div class="nh-inline-actions">
              <%= link_to "Ver paciente", patient_path(@patient), class: "nh-button nh-button--secondary" %>
              <%= link_to "Nuevo control", new_patient_patient_history_path(@patient), class: "nh-button nh-button--ghost" %>
            </div>
          </section>
        </aside>
      </section>
    </div>
  </main>
</div>
