<div class="nh-backoffice nh-dashboard">
  <%= render "shared/nutritionist_sidebar", active: :dashboard %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <%= render "shared/nutritionist_page_header",
        eyebrow: "Sprint 02 · backoffice operativo",
        title: "Hola, #{current_nutritionist.first_name}.",
        description: "Resumen real de pacientes, planes recientes y atención rápida para priorizar tu turno.",
        primary_action: { label: "Crear paciente", path: new_patient_path },
        secondary_action: { label: "Ver pacientes", path: patients_path } %>

      <%= turbo_frame_tag "new_patient" %>

      <section class="nh-stat-grid" aria-label="Métricas del dashboard">
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Pacientes totales</p>
          <p class="nh-stat-card__value"><%= @dashboard_stats[:total_patients] %></p>
          <p class="nh-stat-card__hint">Base actual de pacientes visibles.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Planes activos</p>
          <p class="nh-stat-card__value"><%= @dashboard_stats[:active_plans] %></p>
          <p class="nh-stat-card__hint">Planes vigentes o marcados como activos.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Sin plan activo</p>
          <p class="nh-stat-card__value"><%= @dashboard_stats[:patients_without_active_plan] %></p>
          <p class="nh-stat-card__hint">Pacientes que requieren revisión de plan.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Accesos pendientes</p>
          <p class="nh-stat-card__value"><%= @dashboard_stats[:pending_access] %></p>
          <p class="nh-stat-card__hint">Invitaciones o accesos aún no activos.</p>
        </article>
      </section>

      <section class="nh-grid nh-grid--content">
        <div class="nh-stack">
          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Seguimiento</p>
                <h2 class="nh-section__title">Resumen de pacientes</h2>
                <p class="nh-section__description">Pacientes priorizados por perfil, acceso y plan vigente.</p>
              </div>
              <%= link_to "Listado completo", patients_path, class: "nh-button nh-button--ghost" %>
            </div>

            <% if @patient_summaries.any? %>
              <div class="nh-dashboard__patient-list" id="patient-summary-list">
                <%= render partial: "dashboard_patient_row", collection: @patient_summaries, as: :summary %>
              </div>
            <% else %>
              <%= render "shared/nutritionist_empty_state",
                title: "Aún no tienes pacientes creados.",
                body: "Empieza creando el primer paciente para abrir el flujo de perfil, plan y seguimiento.",
                action: { label: "Crear primer paciente", path: new_patient_path } %>
            <% end %>
          </section>

          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Actividad</p>
                <h2 class="nh-section__title">Planes recientes</h2>
                <p class="nh-section__description">Últimos planes creados o actualizados dentro de tu cartera.</p>
              </div>
            </div>

            <% if @recent_nutrition_plans.any? %>
              <div class="nh-dashboard__plan-list" id="recent-plans-list">
                <%= render partial: "dashboard_plan_row", collection: @recent_nutrition_plans, as: :plan %>
              </div>
            <% else %>
              <%= render "shared/nutritionist_empty_state",
                title: "No hay planes recientes.",
                body: "Cuando prepares planes nutricionales aparecerán aquí con accesos directos a detalle y edición." %>
            <% end %>
          </section>
        </div>

        <aside class="nh-stack">
          <section class="nh-panel">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Atención rápida</p>
                <h2 class="nh-section__title">Frentes abiertos</h2>
                <p class="nh-section__description">Agrupaciones reales para detectar configuración pendiente.</p>
              </div>
            </div>

            <div class="nh-stack">
              <% @dashboard_attention.each do |group_key, group_summaries| %>
                <section class="nh-dashboard__attention-group">
                  <h3 class="nh-dashboard__attention-title"><%= nutritionist_dashboard_attention_copy(group_key) %></h3>

                  <% if group_summaries.any? %>
                    <div class="nh-list">
                      <% group_summaries.each do |summary| %>
                        <article class="nh-list__item">
                          <div>
                            <p class="nh-list__title"><%= summary[:patient].first_name %> <%= summary[:patient].last_name %></p>
                            <p class="nh-list__meta"><%= nutritionist_dashboard_activity_label(summary[:last_activity_at]) %></p>
                          </div>
                          <%= link_to summary[:primary_cta_label], summary[:primary_cta_path], class: "nh-button nh-button--secondary nh-button--small" %>
                        </article>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="nh-muted"><%= nutritionist_dashboard_empty_attention_copy(group_key) %></p>
                  <% end %>
                </section>
              <% end %>
            </div>
          </section>

          <section class="nh-panel nh-dashboard__radar-card">
            <div class="nh-section-header">
              <div>
                <p class="nh-section__eyebrow">Task 3 pendiente</p>
                <h2 class="nh-section__title">Radar de pacientes</h2>
                <p class="nh-section__description">El radar sigue en su vista dedicada; aquí solo queda el acceso limpio dentro del dashboard.</p>
              </div>
            </div>

            <ul class="nh-dashboard__radar-points">
              <li>Sin plan activo</li>
              <li>Sin peso reciente</li>
              <li>Sin comidas registradas</li>
              <li>Acceso de app pendiente</li>
            </ul>

            <%= link_to "Abrir radar", nutritionist_patient_radar_path, class: "nh-button nh-button--primary" %>
          </section>
        </aside>
      </section>
    </div>
  </main>
</div>
