<div class="nh-backoffice nh-patient-radar">
  <%= render "shared/nutritionist_sidebar", active: :radar %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <%= render "shared/nutritionist_page_header",
        eyebrow: "Priorización",
        title: "Radar de Pacientes",
        description: "Priorización automática basada en acceso, plan, peso reciente y actividad alimentaria.",
        secondary_action: { label: "Volver al dashboard", path: nutritionist_dashboard_path } %>

      <% if @radar_entries.any? %>
        <section class="nh-panel">
          <div class="nh-list">
            <% @radar_entries.each do |entry| %>
              <article class="nh-list__item">
                <div>
                  <p class="nh-list__title"><%= entry.patient.first_name %> <%= entry.patient.last_name %></p>
                  <p class="nh-list__meta"><%= entry.reasons.join(" · ").presence || "Sin alertas activas" %></p>
                  <p class="nh-body-copy"><strong>Acción sugerida:</strong> <%= entry.recommended_action %></p>
                </div>

                <div class="nh-inline-actions">
                  <span class="<%= nutritionist_backoffice_badge_class(entry.priority_level == "high" ? "danger" : (entry.priority_level == "medium" ? "warning" : "success")) %>">
                    <%= entry.priority_level.upcase %> · <%= entry.score %>
                  </span>
                  <%= link_to "Ver paciente", patient_path(entry.patient), class: "nh-button nh-button--primary nh-button--small" %>
                </div>
              </article>
            <% end %>
          </div>
        </section>
      <% else %>
        <%= render "shared/nutritionist_empty_state",
          title: "No hay pacientes priorizados en este momento.",
          body: "El radar no detectó alertas relevantes para la cartera actual." %>
      <% end %>
    </div>
  </main>
</div>
