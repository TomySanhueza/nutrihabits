<%= simple_form_for [@patient, @profile], html: { class: "nh-stack" } do |f| %>
  <section class="nh-form-section">
    <div class="nh-form-section__header">
      <h2 class="nh-form-section__title">Base antropométrica</h2>
      <p class="nh-form-section__copy">Peso y altura inicial para contextualizar el seguimiento y el plan.</p>
    </div>

    <div class="nh-form-grid nh-form-grid--two">
      <div>
        <%= f.input :weight,
          label: "Peso (kg)",
          input_html: { class: "nh-form-input", placeholder: "70.5" } %>
      </div>
      <div>
        <%= f.input :height,
          label: "Altura (cm)",
          input_html: { class: "nh-form-input", placeholder: "170" } %>
      </div>
    </div>
  </section>

  <section class="nh-form-section">
    <div class="nh-form-section__header">
      <h2 class="nh-form-section__title">Objetivos y contexto</h2>
      <p class="nh-form-section__copy">Resume metas, hábitos y restricciones que deben guiar el plan.</p>
    </div>

    <div class="nh-form-grid">
      <div>
        <%= f.input :goals,
          as: :text,
          label: "Objetivos",
          input_html: { class: "nh-form-textarea", rows: 4, placeholder: "Pérdida de peso, recomposición corporal, mejora de hábitos..." } %>
      </div>
      <div>
        <%= f.input :lifestyle,
          as: :text,
          label: "Estilo de vida",
          input_html: { class: "nh-form-textarea", rows: 4, placeholder: "Actividad física, horarios, adherencia, preferencias..." } %>
      </div>
    </div>
  </section>

  <section class="nh-form-section">
    <div class="nh-form-section__header">
      <h2 class="nh-form-section__title">Condiciones clínicas</h2>
      <p class="nh-form-section__copy">Incluye antecedentes relevantes, diagnósticos y alertas alimentarias.</p>
    </div>

    <div class="nh-form-grid">
      <div>
        <%= f.input :conditions,
          as: :text,
          label: "Condiciones de salud",
          hint: "Incluye alergias, intolerancias y antecedentes relevantes.",
          input_html: { class: "nh-form-textarea", rows: 4, placeholder: "Hipertensión, celiaquía, alergias, medicamentos..." } %>
      </div>
      <div>
        <%= f.input :diagnosis,
          as: :text,
          label: "Diagnóstico y notas clínicas",
          input_html: { class: "nh-form-textarea", rows: 4, placeholder: "Diagnóstico nutricional, prioridades de intervención y observaciones..." } %>
      </div>
    </div>
  </section>

  <div class="nh-form-actions">
    <%= link_to "Cancelar", patient_path(@patient), class: "nh-button nh-button--secondary" %>
    <%= f.submit "Guardar perfil", class: "nh-button nh-button--primary" %>
  </div>
<% end %>
