<% content_for :hide_navbar, true %>
<div class="container-fluid px-0" style="max-width: 520px; margin: 0 auto; min-height: 100vh; background-color: #ffffff;">
  <div class="px-3 pb-5">
    <header class="d-flex justify-content-between align-items-start pt-3 pb-3">
      <div>
        <h1 class="fs-4 fw-bold mb-1">Compra inteligente</h1>
        <p class="text-muted small mb-0">Genera tu lista según tu pauta y tu supermercado favorito.</p>
      </div>
      <%= link_to pats_dashboard_path, class: "btn btn-link text-secondary p-2 text-decoration-none" do %>
        <i class="bi bi-arrow-left fs-5"></i>
      <% end %>
    </header>

    <section class="card border-0 shadow-sm rounded-4 mb-3" style="background-color: #f8f9fa;">
      <div class="card-body p-3">
        <h2 class="fs-6 fw-bold mb-3">Generar lista</h2>
        <%= form_with url: generate_grocery_lists_path, method: :post, local: true do |f| %>
          <div class="mb-3">
            <%= fields_for :user_supermarket_preference, @preference do |preference_fields| %>
              <%= preference_fields.label :retailer_slug, "Supermercado favorito", class: "form-label small fw-semibold" %>
              <%= preference_fields.select :retailer_slug,
                  options_for_select(@retailer_options, @preference.retailer_slug),
                  {},
                  class: "form-select rounded-3" %>
            <% end %>
          </div>

          <div class="row g-2">
            <div class="col-6">
              <label for="date_from" class="form-label small fw-semibold">Desde</label>
              <%= f.date_field :date_from,
                  value: @active_plan&.start_date || Date.current,
                  class: "form-control rounded-3" %>
            </div>
            <div class="col-6">
              <label for="date_to" class="form-label small fw-semibold">Hasta</label>
              <%= f.date_field :date_to,
                  value: @active_plan&.end_date || Date.current + 6.days,
                  class: "form-control rounded-3" %>
            </div>
          </div>

          <div class="mt-3">
            <%= f.submit "Generar lista", class: "btn btn-dark w-100 py-2 rounded-3 fw-semibold" %>
          </div>
        <% end %>
      </div>
    </section>

    <% if @grocery_list.present? %>
      <section class="card border shadow-sm rounded-4 mb-3">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h2 class="fs-6 fw-bold mb-1">Lista actual</h2>
              <p class="text-muted small mb-0">
                <%= @grocery_list.date_from %> a <%= @grocery_list.date_to %>
              </p>
            </div>
            <span class="badge text-bg-light border">
              <%= SupermarketCatalogProvider.label_for(@grocery_list.retailer_slug) %>
            </span>
          </div>

          <% @grocery_list.grocery_list_items.each do |item| %>
            <div class="border rounded-3 p-3 mb-3">
              <div class="d-flex justify-content-between align-items-start gap-2">
                <div>
                  <p class="fw-semibold mb-1"><%= item.ingredient_name %></p>
                  <p class="small text-muted mb-0">
                    <%= item.quantity_value %> <%= item.quantity_unit %> ·
                    <%= Array(item.meal_types).map(&:to_s).map(&:humanize).join(", ") %>
                  </p>
                </div>
                <span class="badge rounded-pill text-bg-secondary"><%= item.grocery_product_matches.count %> sugerencias</span>
              </div>

              <% if item.grocery_product_matches.any? %>
                <div class="mt-3">
                  <% item.grocery_product_matches.order(:rank).each do |match| %>
                    <div class="bg-light rounded-3 p-2 mb-2">
                      <div class="d-flex justify-content-between align-items-start gap-2">
                        <div>
                          <p class="mb-1 fw-semibold"><%= match.name %></p>
                          <p class="small text-muted mb-0"><%= [match.brand, match.package_size].compact.join(" · ") %></p>
                        </div>
                        <div class="text-end">
                          <p class="mb-1 fw-semibold"><%= match.price %> <%= match.currency %></p>
                          <% if match.product_url.present? %>
                            <%= link_to "Ver", match.product_url, class: "small text-decoration-none", target: "_blank", rel: "noreferrer" %>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="small text-muted mt-3 mb-0">Sin match exacto. Mantén este alimento en tu lista manual.</p>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% else %>
      <section class="card border-0 shadow-sm rounded-4" style="background-color: #f8f9fa;">
        <div class="card-body p-4 text-center">
          <i class="bi bi-basket fs-1 text-secondary"></i>
          <p class="mt-3 mb-1 fw-semibold">Aún no generas una lista</p>
          <p class="small text-muted mb-0">Usa tu pauta activa para crear una compra semanal o por rango.</p>
        </div>
      </section>
    <% end %>
  </div>
</div>
