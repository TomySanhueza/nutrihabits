<% primary_action = patient_primary_action(patient: @patient, profile: @profile, active_plan: @active_plan) %>
<% access_action = patient_access_action(@patient) %>

<div class="nh-backoffice nh-patient-show">
  <%= render "shared/nutritionist_sidebar", active: :patients, patient: @patient %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <section class="nh-panel nh-patient-show__hero" id="summary">
        <div class="nh-patient-show__hero-main">
          <div class="nh-identity">
            <div class="nh-avatar nh-patient-show__hero-avatar"><%= patient_initials(@patient) %></div>
            <div>
              <p class="nh-section__eyebrow">Ficha de paciente</p>
              <h1 class="nh-page-header__title"><%= @patient.first_name %> <%= @patient.last_name %></h1>
              <p class="nh-page-header__description">
                <%= @patient.email %>
                <% if @patient.phone.present? %>
                  · <%= @patient.phone %>
                <% end %>
                <% if @patient.last_seen_at.present? %>
                  · Última actividad app <%= time_ago_in_words(@patient.last_seen_at) %>
                <% end %>
              </p>
            </div>
          </div>

          <div class="nh-pill-list">
            <span class="<%= nutritionist_backoffice_badge_class(onboarding_state_badge_modifier(@patient.onboarding_state)) %>">
              Acceso app: <%= onboarding_state_name(@patient.onboarding_state) %>
            </span>
            <span class="<%= nutritionist_backoffice_badge_class(plan_presence_badge_modifier(@active_plan)) %>">
              <%= @active_plan.present? ? "Plan activo" : "Sin plan activo" %>
            </span>
            <span class="<%= nutritionist_backoffice_badge_class(@profile.present? ? 'success' : 'warning') %>">
              <%= patient_profile_status(@profile) %>
            </span>
          </div>
        </div>

        <div class="nh-inline-actions nh-patient-show__hero-actions">
          <%= link_to primary_action[:label], primary_action[:path], class: "nh-button nh-button--primary" %>
          <%= link_to "Ver planes", patient_nutrition_plans_path(@patient), class: "nh-button nh-button--secondary" %>
          <%= link_to "Nuevo control", new_patient_patient_history_path(@patient), class: "nh-button nh-button--secondary" %>
          <%= button_to access_action[:label], access_action[:path], method: access_action[:method], class: "nh-button nh-button--secondary", form: { class: "nh-inline-form" } %>
        </div>
      </section>

      <nav class="nh-patient-show__subnav" aria-label="Secciones del paciente">
        <%= link_to "Resumen", "#summary", class: "nh-button nh-button--ghost" %>
        <%= link_to "Peso", "#weights", class: "nh-button nh-button--ghost" %>
        <%= link_to "Planes", "#plans", class: "nh-button nh-button--ghost" %>
        <%= link_to "Controles", "#controls", class: "nh-button nh-button--ghost" %>
        <%= link_to "Perfil", "#profile", class: "nh-button nh-button--ghost" %>
      </nav>

      <section class="nh-stat-grid" aria-label="Resumen clínico">
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Peso actual</p>
          <p class="nh-stat-card__value"><%= formatted_weight(@current_weight) %></p>
          <p class="nh-stat-card__hint">
            <% if @weight_entries.any? %>
              Último registro: <%= l(@weight_entries.last[:date], format: :long) %>
            <% elsif @profile&.weight.present? %>
              Fallback desde perfil clínico
            <% else %>
              Aún sin mediciones
            <% end %>
          </p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Cambio reciente</p>
          <p class="nh-stat-card__value nh-patient-show__trend nh-patient-show__trend--<%= weight_trend_modifier(@weight_change) %>"><%= formatted_weight_change(@weight_change) %></p>
          <p class="nh-stat-card__hint"><%= weight_change_caption(@current_weight, @previous_weight) %></p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">IMC</p>
          <p class="nh-stat-card__value"><%= formatted_bmi(@bmi) %></p>
          <p class="nh-stat-card__hint">
            <% if @profile&.height.present? %>
              Altura registrada: <%= formatted_quantity(@profile.height, unit: "cm") %>
            <% else %>
              Falta altura en el perfil
            <% end %>
          </p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Último control</p>
          <p class="nh-stat-card__value">
            <% if @recent_patient_histories.any? %>
              <%= l(@recent_patient_histories.first.visit_date, format: :long) %>
            <% else %>
              Sin controles
            <% end %>
          </p>
          <p class="nh-stat-card__hint">
            <% if @latest_meal_log_at.present? %>
              Última comida registrada: <%= l(@latest_meal_log_at, format: :short) %>
            <% else %>
              Sin comidas registradas
            <% end %>
          </p>
        </article>
      </section>

      <section class="nh-grid nh-grid--two">
        <article class="nh-panel" id="weights">
          <div class="nh-section-header">
            <div>
              <p class="nh-section__eyebrow">Evolución</p>
              <h2 class="nh-section__title">Peso</h2>
            </div>
            <% if @weight_entries.any? %>
              <span class="nh-badge nh-badge--muted"><%= @weight_entries.size %> registro<%= "s" unless @weight_entries.size == 1 %></span>
            <% end %>
          </div>

          <% if @weight_entries.size >= 2 %>
            <% chart_points = weight_chart_points(@weight_entries, width: 640, height: 240, padding: 28) %>
            <div class="nh-patient-show__chart-card">
              <svg viewBox="0 0 640 240" class="nh-patient-show__chart" role="img" aria-label="Gráfico de evolución del peso">
                <defs>
                  <linearGradient id="weightAreaGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#1f5a3c" stop-opacity="0.24"></stop>
                    <stop offset="100%" stop-color="#1f5a3c" stop-opacity="0"></stop>
                  </linearGradient>
                </defs>

                <path d="<%= weight_chart_area_path(chart_points, height: 240, padding: 28) %>" fill="url(#weightAreaGradient)"></path>
                <path d="<%= weight_chart_line_path(chart_points) %>" fill="none" stroke="#1f5a3c" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>

                <% chart_points.each do |point| %>
                  <circle cx="<%= point[:x] %>" cy="<%= point[:y] %>" r="4.5" fill="#16462e"></circle>
                <% end %>
              </svg>

              <div class="nh-patient-show__chart-labels">
                <span><%= l(@weight_entries.first[:date], format: :short) %></span>
                <span><%= l(@weight_entries.last[:date], format: :short) %></span>
              </div>
            </div>
          <% elsif @weight_entries.one? %>
            <%= render "shared/nutritionist_empty_state",
              title: "Solo hay un registro de peso.",
              body: "Necesitas al menos dos puntos para ver tendencia. El último valor registrado es #{formatted_weight(@weight_entries.first[:weight])}." %>
          <% else %>
            <%= render "shared/nutritionist_empty_state",
              title: "Aún no hay registros de peso.",
              body: "La vista usará controles clínicos y registros del paciente cuando existan. Por ahora solo se muestra el resumen disponible." %>
          <% end %>

          <div class="nh-patient-show__subsection">
            <div class="nh-section-header">
              <h3 class="nh-section__title">Últimos registros</h3>
            </div>

            <% if @weight_entries.any? %>
              <div class="nh-list">
                <% @weight_entries.last(5).reverse_each do |entry| %>
                  <article class="nh-list__item">
                    <div>
                      <p class="nh-list__title"><%= formatted_weight(entry[:weight]) %></p>
                      <p class="nh-list__meta">
                        <%= weight_entry_source_name(entry) %> · <%= l(entry[:date], format: :long) %>
                      </p>
                    </div>
                    <% if entry[:nutrition_plan].present? %>
                      <%= link_to "Ver plan", patient_nutrition_plan_path(@patient, entry[:nutrition_plan]), class: "nh-button nh-button--ghost" %>
                    <% end %>
                  </article>
                <% end %>
              </div>
            <% else %>
              <p class="nh-muted">Sin timeline de peso todavía.</p>
            <% end %>
          </div>
        </article>

        <article class="nh-panel">
          <div class="nh-section-header">
            <div>
              <p class="nh-section__eyebrow">Actual</p>
              <h2 class="nh-section__title">Plan vigente</h2>
            </div>
            <% if @active_plan.present? %>
              <span class="<%= nutritionist_backoffice_badge_class(nutrition_plan_status_badge_modifier(@active_plan.status)) %>">
                <%= nutrition_plan_status_name(@active_plan.status) %>
              </span>
            <% end %>
          </div>

          <% if @active_plan.present? %>
            <div class="nh-stack">
              <div>
                <p class="nh-list__title"><%= @active_plan.objective.presence || "Sin objetivo cargado" %></p>
                <p class="nh-list__meta"><%= nutritionist_backoffice_date_range(@active_plan.start_date, @active_plan.end_date) %></p>
              </div>

              <dl class="nh-detail-grid">
                <div>
                  <dt>Calorías</dt>
                  <dd><%= formatted_quantity(@active_plan.calories, unit: "kcal") %></dd>
                </div>
                <div>
                  <dt>Proteína</dt>
                  <dd><%= formatted_quantity(@active_plan.protein, unit: "g") %></dd>
                </div>
                <div>
                  <dt>Carbohidratos</dt>
                  <dd><%= formatted_quantity(@active_plan.carbs, unit: "g") %></dd>
                </div>
                <div>
                  <dt>Grasas</dt>
                  <dd><%= formatted_quantity(@active_plan.fat, unit: "g") %></dd>
                </div>
              </dl>

              <div class="nh-inline-actions">
                <%= link_to "Ver detalle", patient_nutrition_plan_path(@patient, @active_plan), class: "nh-button nh-button--primary" %>
                <%= link_to "Editar plan", edit_patient_nutrition_plan_path(@patient, @active_plan), class: "nh-button nh-button--secondary" %>
              </div>
            </div>
          <% else %>
            <%= render "shared/nutritionist_empty_state",
              title: "Sin plan activo",
              body: "El paciente no tiene un plan vigente hoy. Puedes preparar uno nuevo o revisar el historial de planes anteriores.",
              action: primary_action %>
          <% end %>
        </article>
      </section>

      <section class="nh-panel" id="plans">
        <div class="nh-section-header">
          <div>
            <p class="nh-section__eyebrow">Historial</p>
            <h2 class="nh-section__title">Planes del paciente</h2>
          </div>
          <span class="nh-badge nh-badge--muted"><%= @nutrition_plans.size %> plan<%= "es" unless @nutrition_plans.size == 1 %></span>
        </div>

        <% if @nutrition_plans.any? %>
          <div class="nh-list">
            <% @nutrition_plans.each do |plan| %>
              <article class="nh-list__item nh-patient-show__history-item">
                <div>
                  <p class="nh-list__title"><%= plan.objective.presence || "Plan sin objetivo" %></p>
                  <p class="nh-list__meta"><%= nutritionist_backoffice_date_range(plan.start_date, plan.end_date) %></p>
                  <p class="nh-small-copy"><%= nutrition_plan_macro_summary(plan) %></p>
                </div>

                <div class="nh-inline-actions">
                  <% if @active_plan == plan %>
                    <span class="nh-badge nh-badge--success">Vigente</span>
                  <% end %>
                  <span class="<%= nutritionist_backoffice_badge_class(nutrition_plan_status_badge_modifier(plan.status)) %>">
                    <%= nutrition_plan_status_name(plan.status) %>
                  </span>
                  <%= link_to "Ver detalle", patient_nutrition_plan_path(@patient, plan), class: "nh-button nh-button--ghost" %>
                  <%= link_to "Editar", edit_patient_nutrition_plan_path(@patient, plan), class: "nh-button nh-button--ghost" %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <%= render "shared/nutritionist_empty_state",
            title: "Sin historial de planes.",
            body: "Cuando este paciente tenga planes nutricionales aparecerán aquí con su periodo y macros principales." %>
        <% end %>
      </section>

      <section class="nh-grid nh-grid--two" id="controls">
        <article class="nh-panel">
          <div class="nh-section-header">
            <div>
              <p class="nh-section__eyebrow">Clínico</p>
              <h2 class="nh-section__title">Controles recientes</h2>
            </div>
            <%= link_to "Ver historial completo", patient_patient_histories_path(@patient), class: "nh-button nh-button--ghost" %>
          </div>

          <% if @recent_patient_histories.any? %>
            <div class="nh-list">
              <% @recent_patient_histories.each do |history| %>
                <article class="nh-list__item">
                  <div>
                    <p class="nh-list__title"><%= l(history.visit_date, format: :long) %></p>
                    <p class="nh-list__meta">
                      <%= history.weight.present? ? formatted_weight(history.weight) : "Sin peso registrado" %>
                      <% if history.metrics.present? %>
                        · <%= history.metrics %>
                      <% end %>
                    </p>
                    <% if history.notes.present? %>
                      <p class="nh-small-copy"><%= truncate(history.notes, length: 160) %></p>
                    <% end %>
                  </div>

                  <div class="nh-inline-actions">
                    <%= link_to "Ver control", patient_patient_history_path(@patient, history), class: "nh-button nh-button--ghost" %>
                    <% if history.nutrition_plan.present? %>
                      <%= link_to "Plan asociado", patient_nutrition_plan_path(@patient, history.nutrition_plan), class: "nh-button nh-button--ghost" %>
                    <% end %>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <%= render "shared/nutritionist_empty_state",
              title: "Sin controles clínicos.",
              body: "Todavía no hay visitas registradas para este paciente.",
              action: { label: "Registrar primer control", path: new_patient_patient_history_path(@patient) } %>
          <% end %>
        </article>

        <article class="nh-panel" id="profile">
          <div class="nh-section-header">
            <div>
              <p class="nh-section__eyebrow">Perfil</p>
              <h2 class="nh-section__title">Ficha del paciente</h2>
            </div>
          </div>

          <% if @profile.present? %>
            <dl class="nh-detail-list">
              <div>
                <dt>Altura</dt>
                <dd><%= formatted_quantity(@profile.height, unit: "cm") %></dd>
              </div>
              <div>
                <dt>Peso base</dt>
                <dd><%= formatted_weight(@profile.weight) %></dd>
              </div>
              <div>
                <dt>Objetivos</dt>
                <dd><%= @profile.goals.presence || "Sin objetivos registrados" %></dd>
              </div>
              <div>
                <dt>Condiciones</dt>
                <dd><%= @profile.conditions.presence || "Sin condiciones registradas" %></dd>
              </div>
              <div>
                <dt>Estilo de vida</dt>
                <dd><%= @profile.lifestyle.presence || "Sin información registrada" %></dd>
              </div>
              <div>
                <dt>Diagnóstico</dt>
                <dd><%= @profile.diagnosis.presence || "Sin diagnóstico registrado" %></dd>
              </div>
            </dl>
          <% else %>
            <%= render "shared/nutritionist_empty_state",
              title: "Perfil pendiente",
              body: "Este paciente todavía no tiene ficha clínica. Completa peso, altura y contexto antes de generar un plan.",
              action: { label: "Completar perfil", path: new_patient_profile_path(@patient) } %>
          <% end %>
        </article>
      </section>
    </div>
  </main>
</div>
