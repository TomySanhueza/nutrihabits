<div class="nh-backoffice nh-patients-index">
  <%= render "shared/nutritionist_sidebar", active: :patients %>

  <main class="nh-backoffice__page">
    <div class="nh-page">
      <%= render "shared/nutritionist_page_header",
        eyebrow: "Backoffice clínico",
        title: "Pacientes",
        description: "#{@patient_index_stats[:total_patients]} pacientes visibles para #{current_nutritionist.first_name}.",
        primary_action: { label: "Crear paciente", path: new_patient_path },
        secondary_action: { label: "Ver radar", path: nutritionist_patient_radar_path } %>

      <%= turbo_frame_tag "new_patient" %>

      <section class="nh-stat-grid" aria-label="Resumen de pacientes">
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Pacientes</p>
          <p class="nh-stat-card__value"><%= @patient_index_stats[:total_patients] %></p>
          <p class="nh-stat-card__hint">Base total actualmente asignada.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Con plan activo</p>
          <p class="nh-stat-card__value"><%= @patient_index_stats[:active_plans] %></p>
          <p class="nh-stat-card__hint">Pacientes con seguimiento vigente.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Accesos pendientes</p>
          <p class="nh-stat-card__value"><%= @patient_index_stats[:pending_access] %></p>
          <p class="nh-stat-card__hint">Draft, invitados o suspendidos.</p>
        </article>
        <article class="nh-stat-card">
          <p class="nh-stat-card__label">Sin perfil</p>
          <p class="nh-stat-card__value"><%= @patient_index_stats[:patients_without_profile] %></p>
          <p class="nh-stat-card__hint">Pacientes que aún requieren ficha clínica.</p>
        </article>
      </section>

      <section class="nh-panel">
        <div class="nh-section-header">
          <div>
            <p class="nh-section__eyebrow">Listado</p>
            <h2 class="nh-section__title">Cartera de pacientes</h2>
            <p class="nh-section__description">Vista compacta con acceso, plan vigente y siguiente acción recomendada.</p>
          </div>
        </div>

        <%= form_with url: patients_path, method: :get, class: "nh-patients-index__filters", data: { turbo: false } do |f| %>
          <div class="nh-patients-index__search">
            <%= f.label :search, "Buscar paciente", class: "nh-form-label" %>
            <%= f.text_field :search,
              value: params[:search],
              placeholder: "Nombre, apellido o email",
              class: "nh-form-input" %>
          </div>
          <div class="nh-inline-actions">
            <%= f.submit "Aplicar", class: "nh-button nh-button--secondary" %>
            <% if params[:search].present? %>
              <%= link_to "Limpiar", patients_path, class: "nh-button nh-button--ghost" %>
            <% end %>
          </div>
        <% end %>

        <% if @patient_rows.any? %>
          <div class="nh-patients-index__table-wrap">
            <table class="nh-table">
              <thead>
                <tr>
                  <th>Paciente</th>
                  <th>Acceso y plan</th>
                  <th>Actividad</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% @patient_rows.each do |row| %>
                  <% patient = row[:patient] %>
                  <% primary_action =
                    if row[:profile_complete]
                      row[:active_plan].present? ? { label: "Ver paciente", path: patient_path(patient) } : { label: "Preparar plan", path: new_patient_nutrition_plan_path(patient) }
                    else
                      { label: "Completar perfil", path: new_patient_profile_path(patient) }
                    end %>
                  <% secondary_action =
                    if patient.nutrition_plans.any?
                      { label: "Ver planes", path: patient_nutrition_plans_path(patient) }
                    else
                      { label: "Nuevo control", path: new_patient_patient_history_path(patient) }
                    end %>

                  <tr>
                    <td>
                      <div class="nh-identity">
                        <div class="nh-avatar"><%= patient_initials(patient) %></div>
                        <div>
                          <h3 class="nh-identity__title"><%= link_to "#{patient.first_name} #{patient.last_name}", patient_path(patient), class: "nh-dashboard__row-link" %></h3>
                          <p class="nh-identity__copy"><%= patient.email %></p>
                          <% if patient.phone.present? %>
                            <p class="nh-small-copy"><%= patient.phone %></p>
                          <% end %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <div class="nh-pill-list">
                        <span class="<%= nutritionist_backoffice_badge_class(onboarding_state_badge_modifier(patient.onboarding_state)) %>">
                          <%= onboarding_state_name(patient.onboarding_state) %>
                        </span>
                        <span class="<%= nutritionist_backoffice_badge_class(plan_presence_badge_modifier(row[:active_plan])) %>">
                          <%= row[:active_plan].present? ? "Plan activo" : "Sin plan activo" %>
                        </span>
                      </div>
                      <p class="nh-table__subcopy">
                        <%= patient_profile_status(patient.profile) %>
                        <% if row[:last_weight].present? %>
                          · Último peso <%= number_with_precision(row[:last_weight], precision: 1, strip_insignificant_zeros: true) %> kg
                        <% end %>
                      </p>
                    </td>
                    <td>
                      <p class="nh-body-copy"><%= patient_last_seen_label(row[:last_activity_at]) %></p>
                      <% if row[:active_plan].present? %>
                        <p class="nh-table__subcopy"><%= row[:active_plan].objective.presence || "Plan sin objetivo" %></p>
                      <% else %>
                        <p class="nh-table__subcopy">Sin objetivo vigente para hoy.</p>
                      <% end %>
                    </td>
                    <td>
                      <div class="nh-inline-actions">
                        <%= link_to primary_action[:label], primary_action[:path], class: "nh-button nh-button--primary nh-button--small" %>
                        <%= link_to secondary_action[:label], secondary_action[:path], class: "nh-button nh-button--secondary nh-button--small" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <%= render "shared/nutritionist_empty_state",
            title: params[:search].present? ? "No hubo coincidencias para la búsqueda." : "No tienes pacientes registrados.",
            body: params[:search].present? ? "Ajusta el término de búsqueda o limpia el filtro para ver toda la cartera." : "Crea tu primer paciente para empezar el seguimiento clínico.",
            action: params[:search].present? ? nil : { label: "Crear primer paciente", path: new_patient_path } %>
        <% end %>
      </section>
    </div>
  </main>
</div>
